# RunPod
RUNPOD_API_KEY=your_runpod_api_key

# HuggingFace (required for gated Gemma model)
HF_TOKEN=hf_your_token_here

# S3/R2 Storage (for returning video URLs instead of base64)
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com  # For R2
S3_REGION=auto
S3_PUBLIC_URL=https://cdn.yourdomain.com  # Optional CDN URL
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Model directory (default: /app/models if baked, /runpod-volume/models if network volume)
MODEL_DIR=/app/models
